
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'antonio.anacleto@gmail.com';
    }
    
    // Public data is readable by anyone
    match /publicData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Statistical data is readable by anyone
    match /statisticalData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Do not allow listing all user profiles
      // Allow creation if the user is creating their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isExistingDoc();
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    match /simulationModelDefinitions/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read, write: if false; // Should be managed server-side
    }

    match /dataSources/{dataSourceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /publicLegislationQueries/{queryId} {
      allow read: if true;
      allow create: if true; // Allow anyone to create for caching purposes
      allow update, delete: if isAdmin();
    }

    match /communityProposals/{proposalId} {
      // PUBLIC ACCESS: Anyone can get a single proposal or list all proposals.
      allow get: if true;
      allow list: if true;

      // AUTHENTICATED-ONLY ACTIONS
      // Create: Only signed-in users can create a new proposal.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Update (Vote): Allow authenticated users to vote, but only once.
      // The update can only modify the 'voteCount' and 'votedBy' fields.
      allow update: if isSignedIn() 
                    && request.auth.uid !in resource.data.votedBy
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'votedBy']);

      // Delete: Allow the owner of the proposal or an admin to delete it.
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }
    
    match /contactMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      match /simulationScenarios/{scenarioId} {
        allow read, write: if isOwner(userId);
      }

      match /savedDataViews/{viewId} {
        allow read, write: if isOwner(userId);
      }

      match /factChecks/{factCheckId} {
        allow read, write: if isOwner(userId);
      }

      match /legislationQueries/{queryId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
