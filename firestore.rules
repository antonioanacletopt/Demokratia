
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'antonio.anacleto@gmail.com';
    }
    
    // Public data is readable by anyone
    match /publicData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Statistical data is readable by anyone
    match /statisticalData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Do not allow listing all user profiles
      // Allow creation if the user is creating their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isExistingDoc();
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    match /simulationModelDefinitions/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read, write: if false; // Should be managed server-side
    }

    match /dataSources/{dataSourceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /publicLegislationQueries/{queryId} {
      allow read: if true;
      allow create: if true; // Allow anyone to create for caching purposes
      allow update, delete: if isAdmin();
    }

    match /communityProposals/{proposalId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.voteCount == 0
                    && request.resource.data.votedBy.size() == 0;
      allow update: if isSignedIn()
                    && !(request.auth.uid in resource.data.votedBy)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'votedBy'])
                    && request.resource.data.voteCount == resource.data.voteCount + 1
                    && request.resource.data.votedBy == resource.data.votedBy.union([request.auth.uid]);
      allow delete: if isAdmin();
    }
    
    match /contactMessages/{messageId} {
      allow create: if isSignedIn();

      // Admins can list all messages. This is required for the admin page.
      allow list: if isAdmin();
      
      // An admin or the message owner can get a single message.
      allow get: if isAdmin() || (isExistingDoc() && resource.data.userId == request.auth.uid);

      // Admins can update or delete any message.
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      match /simulationScenarios/{scenarioId} {
        allow read, write: if isOwner(userId);
      }

      match /savedDataViews/{viewId} {
        allow read, write: if isOwner(userId);
      }

      match /factChecks/{factCheckId} {
        allow read, write: if isOwner(userId);
      }

      match /legislationQueries/{queryId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
