
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'antonio.anacleto@gmail.com';
    }
    
    // Public data is readable by anyone
    match /publicData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Statistical data is readable by anyone
    match /statisticalData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Do not allow listing all user profiles
      // Allow creation if the user is creating their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isExistingDoc();
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    match /simulationModelDefinitions/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read, write: if false; // Should be managed server-side
    }

    match /dataSources/{dataSourceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /publicLegislationQueries/{queryId} {
      allow read: if true;
      allow create: if true; // Allow anyone to create for caching purposes
      allow update, delete: if isAdmin();
    }

    match /communityProposals/{proposalId} {
      // Allow public read access to all proposals
      allow get, list: if true;
    
      // Allow authenticated users to create proposals
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.voteCount == 0
                    && request.resource.data.votedBy.size() == 0;
    
      // Allow authenticated users to vote (update)
      allow update: if isSignedIn()
                    && !(request.auth.uid in resource.data.votedBy) // User has not voted yet
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'votedBy']) // Only voteCount and votedBy can change
                    && request.resource.data.voteCount == resource.data.voteCount + 1 // voteCount increments by 1
                    && request.resource.data.votedBy == resource.data.votedBy.union([request.auth.uid]); // Adds user's UID to votedBy
    
      // Allow admins to delete proposals
      allow delete: if isAdmin();
    }
    
    match /contactMessages/{messageId} {
      // Admins can do anything.
      allow read, write: if isAdmin();
    
      // Authenticated users can create messages for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Authenticated users can get their own single message.
      allow get: if isOwner(resource.data.userId);
      
      // Authenticated users can list their own messages,
      // as long as the query filters by their user ID.
      allow list: if isSignedIn() && request.query.where.userId == request.auth.uid;
    }

    match /users/{userId} {
      match /simulationScenarios/{scenarioId} {
        allow read, write: if isOwner(userId);
      }

      match /savedDataViews/{viewId} {
        allow read, write: if isOwner(userId);
      }

      match /factChecks/{factCheckId} {
        allow read, write: if isOwner(userId);
      }

      match /legislationQueries/{queryId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
