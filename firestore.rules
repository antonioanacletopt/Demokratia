
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Demokratia Portugal: Security Rules
     * Consolidada para acesso master do António e gestão de todas as coleções.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'id5hDeMIVZeR9i9HG5vvqnjEto32' ||
        request.auth.token.email == 'antonio.anacleto@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    // Perfis de utilizador
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Sessões de Analytics (Visitas)
    match /analytics_sessions/{sessionId} {
      allow create: if true; // Qualquer pessoa pode registar um acesso
      allow read, list: if isAdmin();
    }

    // Refutações da IA
    match /refutations/{refutationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Mensagens de Contacto
    match /contactMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
    }

    // Propostas da Comunidade
    match /communityProposals/{proposalId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Cache e Dados Públicos
    match /translations_cache/{id} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    match /news_feed_cache/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /publicData/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /statisticalData/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /dataSources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Consultas Públicas e Repositórios de Resultados IA
    match /publicStatisticQueries/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /publicLegislationQueries/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /publicSimulations/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    match /publicFactChecks/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Funções Administrativas
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
