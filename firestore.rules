/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model where all
 * data is private to the user who created it, except for designated public
 * collections. Access control is primarily managed through the document path.
 *
 * Data Structure:
 * - User-generated content (`profiles`, `simulationScenarios`) is organized
 *   hierarchically under a top-level `/users/{userId}` collection. This
 *   inherently isolates each user's data.
 * - Public data (`publicData`, `statisticalData`) is stored in top-level
 *   collections and is world-readable.
 *
 * Key Security Decisions:
 * - User Enumeration Disabled: Listing the top-level `/users` collection is
 *   explicitly forbidden to prevent scraping user IDs.
 * - Path-Based Security: The primary authorization check for all user-owned
 *   data relies on matching the `{userId}` in the path with the authenticated
 *   user's UID. This is fast, secure, and avoids costly database reads (`get`
 *   calls) in rules.
 * - Public Data is Read-Only for Clients: The `publicData` and `statisticalData`
 *   collections are readable by anyone but writable only via admin processes
 *   (e.g., seeding scripts), not directly by app users.
 * - Relational Integrity: On document creation, rules enforce that internal
 *   ID fields (like `userId`) match the corresponding IDs in the document's path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- UserProfile Validation ---
    function hasValidUserProfileDataForCreate(userId) {
      // The id is no longer part of the schema, so we check other fields
      return request.resource.data.email == request.auth.token.email;
    }

    function hasValidUserProfileDataForUpdate() {
       return request.resource.data.email == resource.data.email;
    }

    // --- SimulationScenario Validation ---
    function hasValidScenarioDataForCreate(userId) {
      return request.resource.data.userId == userId;
    }

    function hasValidScenarioDataForUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }

    // ------------------------------------------------------------------------
    // Publicly Readable Collections
    // ------------------------------------------------------------------------

    /**
     * @description Public data for dashboard charts (GDP, inflation, etc.).
     *              Readable by anyone, not writable by clients.
     */
    match /publicData/{dataSetId} {
      allow get: if true;
      allow list: if true;
      allow write: if false; // Should only be seeded by admin/backend
    }

    /**
     * @description Public statistical data for the explorer page.
     *              Readable by anyone, not writable by clients.
     */
    match /statisticalData/{dataId} {
      allow get: if true;
      allow list: if true;
      allow write: if false; // Should only be seeded by admin/backend
    }

    // ------------------------------------------------------------------------
    // User-Specific Collections
    // ------------------------------------------------------------------------

    /**
     * @description Manages user-specific data. Listing all users is forbidden.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && hasValidUserProfileDataForCreate(userId);
      allow update: if isOwner(userId) && hasValidUserProfileDataForUpdate();
      allow delete: if isOwner(userId);

      /**
       * @description Manages user-created economic simulation scenarios.
       *              Access is restricted to the owner of the user profile.
       */
      match /simulationScenarios/{scenarioId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidScenarioDataForCreate(userId);
        allow update: if isOwner(userId) && hasValidScenarioDataForUpdate();
        allow delete: if isOwner(userId);
      }
    }
  }
}
