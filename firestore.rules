rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Demokratia Portugal: Security Rules Summary
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    // Perfis de utilizador
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
      
      // Subcoleções do utilizador (Dashboards, Fact-checks, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Refutações da IA
    match /refutations/{refutationId} {
      allow list: if isSignedIn();
      allow get: if (resource.data.status == 'approved') || isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Mensagens de Contacto
    match /contactMessages/{messageId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if (resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Propostas da Comunidade
    match /communityProposals/{proposalId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Para votar ou editar
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Cache de Traduções e Notícias (Público/Autenticado)
    match /translations_cache/{id} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    match /news_feed_cache/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Dados Públicos e Estatísticos
    match /publicData/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /statisticalData/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /dataSources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Consultas Públicas (Cache de IA)
    match /publicStatisticQueries/{id} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    match /publicLegislationQueries/{id} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    match /publicSimulations/{id} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    // Funções Administrativas
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list, create, update, delete: if false;
    }
  }
}