
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    // Public data is readable by anyone
    match /publicData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Statistical data is readable by anyone
    match /statisticalData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Do not allow listing all user profiles
      // Allow creation if the user is creating their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isExistingDoc();
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    match /simulationModelDefinitions/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read, write: if false; // Should be managed server-side
    }
    
    match /users/{userId} {
      match /simulationScenarios/{scenarioId} {
        allow read, write: if isOwner(userId);
      }

      match /savedDataViews/{viewId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}

    