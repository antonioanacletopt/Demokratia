
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Demokratia Portugal: Security Rules v1.3
     * ATENÇÃO: Coleções públicas têm prioridade absoluta no topo.
     */

    // --- 1. Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'id5hDeMIVZeR9i9HG5vvqnjEto32' ||
        request.auth.token.email == 'antonio.anacleto@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // --- 2. Public Content (Read Access for ALL, including anonymous) ---

    match /publicSimulations/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /publicFactChecks/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /publicLegislationQueries/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /publicStatisticQueries/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /statisticalData/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dataSources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /communityProposals/{proposalId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- 3. User Profiles & Private Data ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- 4. System & Analytics ---

    match /analytics_sessions/{sessionId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
    }

    match /refutations/{refutationId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /translations_cache/{id} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    match /news_feed_cache/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
