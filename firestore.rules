
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'antonio.anacleto@gmail.com';
    }
    
    // Public data is readable by anyone
    match /publicData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Statistical data is readable by anyone
    match /statisticalData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Do not allow listing all user profiles
      // Allow creation if the user is creating their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isExistingDoc();
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    match /simulationModelDefinitions/{modelId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow read, write: if false; // Should be managed server-side
    }

    match /dataSources/{dataSourceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /publicLegislationQueries/{queryId} {
      allow read: if true;
      allow create: if true; // Allow anyone to create for caching purposes
      allow update, delete: if isAdmin();
    }

    match /communityProposals/{proposalId} {
      // Allow public read access for everyone (get and list).
      allow read: if true;
    
      // Allow creation for any signed-in user.
      // The submitted data must have the correct owner userId and start with a voteCount of 0.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.voteCount == 0
                    && request.resource.data.votedBy.size() == 0;
    
      // Allow updates for voting.
      allow update: if isSignedIn()
                    // The user must not have voted before.
                    && !(request.auth.uid in resource.data.votedBy)
                    // The only fields that can change are voteCount and votedBy.
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'votedBy'])
                    // The voteCount must be incremented by exactly 1.
                    && request.resource.data.voteCount == resource.data.voteCount + 1
                    // The user's UID must be the only one added to the votedBy array.
                    && request.resource.data.votedBy == resource.data.votedBy.union([request.auth.uid]);
      
      // Only an admin can delete a proposal.
      allow delete: if isAdmin();
    }
    
    match /contactMessages/{messageId} {
      allow create: if isSignedIn();

      // Admins can read/update/delete any message.
      // Users can only read their own messages.
      // This rule requires the client to query with `where('userId', '==', auth.uid)`.
      allow read: if isAdmin() || (isExistingDoc() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      match /simulationScenarios/{scenarioId} {
        allow read, write: if isOwner(userId);
      }

      match /savedDataViews/{viewId} {
        allow read, write: if isOwner(userId);
      }

      match /factChecks/{factCheckId} {
        allow read, write: if isOwner(userId);
      }

      match /legislationQueries/{queryId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
