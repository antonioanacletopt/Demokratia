/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model for user-specific data, while allowing
 * public read access for non-sensitive, shared data.
 *
 * Data Structure: All user-specific data is hierarchically nested under the `/users/{userId}` path. A separate top-level
 * collection, `/publicData`, is used for information that is accessible to all users. This structural segregation
 * ensures that private data is isolated, while public data is efficiently served.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only ever read or write documents within their own `/users/{userId}` path.
 * - Public Data Access: All users (authenticated or not) can read from the `/publicData` and `/statisticalData` collections. Write access is restricted to signed-in users.
 * - No User Enumeration: Listing the top-level `/users` collection is explicitly disallowed to protect user privacy.
 * - Path-Based Security: For private data, authorization is primarily derived from the `{userId}` parameter in the
 *   document path, checked against the authenticated user's UID.
 *
 * Denormalization for Authorization: To ensure performant and simple security rules, ownership and relational information (e.g., `userId`)
 * is denormalized directly onto every private document. This allows rules to validate ownership by looking at the document's data itself,
 * avoiding slow and costly `get()` calls to parent documents.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId from the path.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a document currently exists in Firestore.
     * Used to prevent updates or deletes on non-existent documents.
     */
    function isExistingDocument() {
      return resource != null;
    }

    /**
     * Combines ownership and existence checks for state-changing operations.
     * Ensures an authenticated owner is modifying an existing document.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDocument();
    }
    
    //-------------------------------------------------------------------------
    // Public Data Rules
    //-------------------------------------------------------------------------

    /**
     * @description Rules for public data sets. Allows anyone to read, but only signed-in users to write.
     * @path /publicData/{dataSetId}
     * @allow (get, list) Any user, authenticated or not, can read public data.
     * @allow (write) Signed-in users can write to seed the data.
     * @principle Provides public, read-only access to shared application data, with secured write for admin/seeding.
     */
    match /publicData/{dataSetId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }
    
    /**
     * @description Rules for complex statistical data sets. Allows anyone to read, but only signed-in users to write.
     * @path /statisticalData/{dataId}
     * @allow (get, list) Any user, authenticated or not, can read statistical data.
     * @allow (write) Signed-in users can write to seed the data.
     * @principle Provides public, read-only access to structured statistical data, with secured write for admin/seeding.
     */
    match /statisticalData/{dataId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    //-------------------------------------------------------------------------
    // User Profile Rules
    //-------------------------------------------------------------------------

    /**
     * @description Rules for a user's own profile document. Users can create, read, and update their own profile. Deletion is also allowed.
     * @path /users/{userId}
     * @allow (create) An authenticated user with uid 'user_abc' creating their own profile at '/users/user_abc'.
     * @deny (get) User 'user_xyz' trying to read the profile at '/users/user_abc'.
     * @principle Restricts access to a user's own data tree and enforces self-creation. Prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      //-----------------------------------------------------------------------
      // Simulation Scenario Rules
      //-----------------------------------------------------------------------

      /**
       * @description Rules for a user's simulation scenarios. Users have full CRUD access to their own scenarios.
       * @path /users/{userId}/simulationScenarios/{scenarioId}
       * @allow (create) User 'user_abc' creating a new scenario at '/users/user_abc/simulationScenarios/new_scenario'.
       * @deny (list) User 'user_xyz' trying to list scenarios at '/users/user_abc/simulationScenarios'.
       * @principle Enforces document ownership within a user's private subcollection and validates relational integrity on writes.
       */
      match /simulationScenarios/{scenarioId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        //---------------------------------------------------------------------
        // Simulation Run Rules
        //---------------------------------------------------------------------

        /**
         * @description Rules for a simulation run, which is a child of a scenario. Access is controlled by the top-level user owner.
         * @path /users/{userId}/simulationScenarios/{scenarioId}/simulationRuns/{runId}
         * @allow (get) User 'user_abc' reading a simulation run at '/users/user_abc/simulationScenarios/scenario_123/simulationRuns/run_456'.
         * @deny (create) User 'user_abc' creating a run where the document's 'scenarioId' does not match the path.
         * @principle Enforces ownership from the top-level user path and validates relational integrity with both the user and parent scenario.
         */
        match /simulationRuns/{runId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId)
                       && request.resource.data.userId == userId
                       && request.resource.data.scenarioId == scenarioId;
          allow update: if isExistingOwner(userId)
                       && request.resource.data.userId == resource.data.userId
                       && request.resource.data.scenarioId == resource.data.scenarioId;
          allow delete: if isExistingOwner(userId);
        }
      }

      //-----------------------------------------------------------------------
      // Saved Data Exploration Rules
      //-----------------------------------------------------------------------

      /**
       * @description Rules for a user's saved data explorations. Users have full CRUD access to their own saved explorations.
       * @path /users/{userId}/savedDataExplorations/{explorationId}
       * @allow (update) User 'user_abc' updating their own exploration at '/users/user_abc/savedDataExplorations/explore_789'.
       * @deny (delete) User 'user_xyz' trying to delete an exploration at '/users/user_abc/savedDataExplorations/explore_789'.
       * @principle Enforces document ownership within a user's private subcollection and validates relational integrity on writes.
       */
      match /savedDataExplorations/{explorationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}

    