
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'antonio.anacleto@gmail.com';
    }
    
    match /userProfiles/{userId} {
      allow get, create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /translations_cache/{id} {
      allow read: if true;
      allow create: if true; // Permite que qualquer utilizador contribua para a cache global
    }

    match /communityProposals/{proposalId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // Outras coleções seguem a mesma lógica de acesso público ou privado conforme necessário
    match /{path=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
