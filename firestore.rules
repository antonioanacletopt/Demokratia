rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
      * Demokratia Portugal: Security Rules v4.0
      * - Adiciona regras abrangentes para todas as coleções, incluindo `analytics_sessions` e `publicData`.
      * - Corrige as permissões da coleção `users` para permitir a leitura por parte dos administradores.
      */

    // --- 1. Funções Auxiliares Globais ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'id5hDeMIVZeR9i9HG5vvqnjEto32' ||
        request.auth.token.email == 'antonio.anacleto@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    
    function isCreatingOwn() {
      return request.auth.uid == request.resource.data.userId;
    }

    // --- 2. Dados de Utilizador --- //
    
    match /users/{userId} {
      allow read, list: if isAdmin();
      allow write: if isOwner(userId);
    }
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // --- 3. Coleções com Dados de Utilizador (Padrão de Segurança) --- //

    match /simulations/{id} {
      allow list, read: if true;
      allow create: if isSignedIn() && isCreatingOwn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /fact-checks/{id} {
      allow list, read: if true;
      allow create: if isSignedIn() && isCreatingOwn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /legislation-queries/{id} {
      allow list, read: if true;
      allow create: if isSignedIn() && isCreatingOwn();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /communityProposals/{id} {
      allow list: if true;
      allow read: if true;
      allow create: if isSignedIn() && isCreatingOwn();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /refutations/{id} {
        allow list: if isAdmin();
        allow create: if isSignedIn() && isCreatingOwn();
        allow read, update, delete: if isAdmin();
    }

    match /contactMessages/{id} {
        allow list, read, delete, update: if isAdmin();
        allow create: if isSignedIn();
    }

    // --- 4. Dados Públicos e Caches do Sistema --- //

    match /publicData/{id} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /publicSimulations {
      allow list: if true;
    }
    match /publicSimulations/{id} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    match /publicScenarios {
      allow list: if true;
    }
    match /publicScenarios/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /publicFactChecks {
      allow list: if true;
    }
    match /publicFactChecks/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /statisticalData {
      allow list: if true;
    }
    match /statisticalData/{id} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
    }

    match /dataSources {
      allow list: if true;
    }
    match /dataSources/{id} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }
    
    match /publicStatisticQueries {
      allow list: if true;
    }
    match /publicStatisticQueries/{id} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
    }

    match /publicLegislationQueries {
      allow list: if true;
    }
    match /publicLegislationQueries/{id} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
    }
    
    // --- 5. Coleções Internas e de Sistema --- //

    match /analytics_sessions/{id} {
        allow create: if true; // Qualquer pessoa pode criar uma sessão
        allow list, read: if isAdmin(); // Apenas admins podem ler os dados
    }

    match /translations_cache/{id} {
        allow read: if true;
        allow write: if isSignedIn();
    }

    match /budgets/{userId} {
        allow read, write: if isOwner(userId);
    }

    match /news_feed_cache/{id} {
        allow read: if true;
        allow write: if isSignedIn();
    }
    
    match /roles_admin/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
