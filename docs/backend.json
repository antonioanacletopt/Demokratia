
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores core information and preferences for a registered user.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "preferredLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "emailNotifications": { "type": "boolean" },
            "weeklyNewsletter": { "type": "boolean" }
          },
          "required": ["emailNotifications", "weeklyNewsletter"]
        }
      },
      "required": ["id", "email", "createdAt", "updatedAt"]
    },
    "TranslationCache": {
      "title": "TranslationCache",
      "type": "object",
      "description": "Caches AI-generated translations to minimize API costs.",
      "properties": {
        "originalText": { "type": "string" },
        "translatedText": { "type": "string" },
        "targetLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["originalText", "translatedText", "targetLanguage", "createdAt"]
    },
    "CommunityProposal": {
      "title": "Community Proposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "voteCount": { "type": "number" },
        "votedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "userName", "title", "description", "createdAt", "voteCount", "votedBy"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles.",
          "params": [{ "name": "userId", "description": "UID" }]
        }
      },
      {
        "path": "/translations_cache/{cacheId}",
        "definition": {
          "entityName": "TranslationCache",
          "schema": { "$ref": "#/backend/entities/TranslationCache" },
          "description": "Global cache for AI translations.",
          "params": [{ "name": "cacheId", "description": "Unique ID for the translation pair." }]
        }
      },
      {
        "path": "/communityProposals/{proposalId}",
        "definition": {
          "entityName": "CommunityProposal",
          "schema": { "$ref": "#/backend/entities/CommunityProposal" },
          "description": "Community shared proposals.",
          "params": [{ "name": "proposalId", "description": "Proposal ID" }]
        }
      }
    ]
  }
}
