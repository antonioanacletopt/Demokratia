
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores basic information and settings for a user within the Demokratia Portugal application.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredLanguage": { "type": "string" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "emailNotifications": { "type": "boolean" },
            "weeklyNewsletter": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "email", "createdAt", "updatedAt"]
    },
    "Refutation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Refutation",
      "type": "object",
      "description": "Represents a user-submitted claim to refute specific AI-generated information.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "aiContentIdentifier": { "type": "string" },
        "refutationText": { "type": "string" },
        "evidenceLinks": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submissionDate": { "type": "string", "format": "date-time" },
        "adminReviewDate": { "type": "string", "format": "date-time" },
        "adminNotes": { "type": "string" }
      },
      "required": ["id", "userId", "aiContentIdentifier", "refutationText", "status", "submissionDate"]
    },
    "VisitorSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VisitorSession",
      "type": "object",
      "description": "Logs an individual access session to the app for analytics.",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isAnonymous": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "timestamp", "isAnonymous"]
    },
    "MacroScenario": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MacroScenario",
      "type": "object",
      "description": "A user-created economic scenario with custom parameters and AI feedback.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "parameters": { "type": "object" },
        "results": { "type": "object" },
        "aiFeedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "parameters", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Individual user profiles and settings."
        }
      },
      {
        "path": "/refutations/{refutationId}",
        "definition": {
          "entityName": "Refutation",
          "description": "User-submitted corrections to AI content."
        }
      },
      {
        "path": "/analytics_sessions/{sessionId}",
        "definition": {
          "entityName": "VisitorSession",
          "description": "Anonymous and registered user access logs."
        }
      },
      {
        "path": "/publicSimulations/{simId}",
        "definition": {
          "entityName": "SimulationCache",
          "description": "Publicly cached economic simulations."
        }
      },
      {
        "path": "/publicFactChecks/{checkId}",
        "definition": {
          "entityName": "FactCheckCache",
          "description": "Publicly cached fact verification results."
        }
      },
      {
        "path": "/publicLegislationQueries/{queryId}",
        "definition": {
          "entityName": "LegislationCache",
          "description": "Publicly cached legal queries and analysis."
        }
      },
      {
        "path": "/publicScenarios/{scenarioId}",
        "definition": {
          "entityName": "MacroScenario",
          "description": "Publicly shared macroeconomic policy exercises."
        }
      }
    ]
  }
}
