
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores basic information and settings for a user.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Refutation": {
      "title": "Refutation",
      "type": "object",
      "description": "User-submitted corrections to AI content.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "aiContentIdentifier": { "type": "string" },
        "refutationText": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      }
    },
    "TranslationCache": {
      "title": "TranslationCache",
      "type": "object",
      "description": "Caches AI translations.",
      "properties": {
        "originalText": { "type": "string" },
        "translatedText": { "type": "string" },
        "targetLanguage": { "type": "string" }
      }
    },
    "FamilyBudget": {
      "title": "FamilyBudget",
      "type": "object",
      "description": "A user's saved family budget scenario.",
      "properties": {
        "userId": { "type": "string" },
        "profile": { "type": "object" },
        "expenses": { "type": "object" },
        "aiAnalysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profile data." },
    "/refutations/{id}": { "schema": "Refutation", "description": "Global refutations." },
    "/translations_cache/{id}": { "schema": "TranslationCache", "description": "Translation memory." },
    "/publicScenarios/{id}": { "schema": "object", "description": "Public macro scenarios." },
    "/publicSimulations/{id}": { "schema": "object", "description": "Public policy simulations." },
    "/publicFactChecks/{id}": { "schema": "object", "description": "Public verified claims." },
    "/publicLegislationQueries/{id}": { "schema": "object", "description": "Public legal queries." }
  }
}
