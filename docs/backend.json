
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores basic information and settings for a user within the Demokratia Portugal application.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "preferredLanguage": { "type": "string" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "emailNotifications": { "type": "boolean" },
            "weeklyNewsletter": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "email", "createdAt", "updatedAt"]
    },
    "Refutation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Refutation",
      "type": "object",
      "description": "Represents a user-submitted claim to refute specific AI-generated information.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "aiContentIdentifier": { "type": "string" },
        "refutationText": { "type": "string" },
        "evidenceLinks": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submissionDate": { "type": "string", "format": "date-time" },
        "adminReviewDate": { "type": "string", "format": "date-time" },
        "adminNotes": { "type": "string" }
      },
      "required": ["id", "userId", "aiContentIdentifier", "refutationText", "status", "submissionDate"]
    },
    "TranslationCache": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TranslationCache",
      "type": "object",
      "description": "Caches AI-generated translations to save costs and improve performance.",
      "properties": {
        "originalText": { "type": "string" },
        "translatedText": { "type": "string" },
        "targetLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["originalText", "translatedText", "targetLanguage", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Individual user profiles and settings."
        }
      },
      {
        "path": "/refutations/{refutationId}",
        "definition": {
          "entityName": "Refutation",
          "description": "User-submitted corrections to AI content."
        }
      },
      {
        "path": "/translations_cache/{id}",
        "definition": {
          "entityName": "TranslationCache",
          "description": "Global cache for AI translations."
        }
      }
    ]
  }
}
